    "import sqlite3\n",
    "import pandas as pd\n",
    "\n",
    "conn = sqlite3.connect(\"../sql/organizational_insights.db\")\n",
    "df = pd.read_sql(\"SELECT * FROM audit_log ORDER BY timestamp DESC\", conn)\n",
    "conn.close()\n",
    "\n",
    "display(df)"
